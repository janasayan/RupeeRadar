# Database
DATABASE_URL=sqlite:///./rupeeradar.db

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# CORS (comma-separated origins)
# In production, add your Vercel URL here
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Session retention
SESSION_TTL_HOURS=24

# Groq LLM (required from Phase 2 for AI categorization & insights)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Deployment ────────────────────────────────────────────────────────────────
# Set in Railway: CORS_ORIGINS must include the Vercel production URL
# Set in Vercel: points to the Railway backend URL
VITE_API_BASE_URL=https://your-railway-url.up.railway.app
